#include <Servo.h>

Servo servo[6];

int joyPins[6] = {A0, A1, A2, A3, A4, A5};
int servoPins[6] = {2, 3, 4, 5, 6, 7};

int pos[6] = {90, 0, 0, 95, 90, 0};

void setup() {
  for (int i = 0; i < 6; i++) {
    servo[i].attach(servoPins[i]);
    servo[i].write(pos[i]);
  }
}

void loop() {
  for (int i = 0; i < 6; i++) {

    int val = analogRead(joyPins[i]);

    // STRONG DEAD ZONE (no movement near center)
    if (val > 560) {
      pos[i] += 1;
    }
    else if (val < 460) {
      pos[i] -= 1;
    }
    // else → do nothing (prevents jitter)

    pos[i] = constrain(pos[i], 0, 180);

    servo[i].write(pos[i]);
  }

  delay(25); // slower = smoother & less jitter
}
